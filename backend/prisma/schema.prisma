// Hello Team Workforce Hub - Database Schema
// Backend: Node.js + TypeScript
// Database: PostgreSQL

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============================================
// ENUMS
// ============================================

enum UserRole {
  SUPER_ADMIN
  ADMIN
  OPERATIONS
  HR
  FINANCE
  SUPPORT
  CLIENT
  EMPLOYEE
}

enum UserStatus {
  ACTIVE
  INACTIVE
  SUSPENDED
}

enum WorkSessionStatus {
  ACTIVE
  ON_BREAK
  COMPLETED
}

enum ApprovalStatus {
  PENDING
  APPROVED
  AUTO_APPROVED
  REJECTED
  REVISION_REQUESTED
}

enum LeaveType {
  PAID
  UNPAID
}

enum AgreementType {
  WEEKLY
  BI_WEEKLY
  MONTHLY
}

enum OnboardingStatus {
  PENDING_AGREEMENT
  COMPLETED
}

enum KycStatus {
  PENDING
  APPROVED
  REJECTED
  RESUBMITTED
}

enum PaidLeaveEntitlementType {
  NONE // No paid leave
  FIXED // Fixed yearly allocation
  FIXED_HALF_YEARLY // Fixed half-yearly allocation
  ACCRUED // Accrued over time
  MILESTONE // Milestone-based eligibility
}

enum LeaveStatus {
  PENDING
  APPROVED_BY_CLIENT
  APPROVED
  REJECTED
}

enum TicketStatus {
  OPEN
  IN_PROGRESS
  RESOLVED
  CLOSED
}

enum TicketPriority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

// ============================================
// ROLES & PERMISSIONS (Dynamic RBAC)
// ============================================

model Role {
  id          String   @id @default(uuid())
  name        String   @unique // e.g., "SUPER_ADMIN", "ADMIN", "OPERATIONS"
  displayName String // e.g., "Super Admin", "Administrator"
  description String?
  isSystem    Boolean  @default(false) // System roles cannot be deleted
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Relations
  permissions RolePermission[]
  users       User[]

  @@map("roles")
}

model RolePermission {
  id         String   @id @default(uuid())
  roleId     String
  permission String // e.g., "employees.view", "clients.create"
  createdAt  DateTime @default(now())

  role Role @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@unique([roleId, permission])
  @@map("role_permissions")
}

// ============================================
// USER & AUTHENTICATION
// ============================================

model User {
  id                   String     @id @default(uuid())
  email                String     @unique
  password             String
  role                 UserRole // Legacy role enum (for backward compatibility)
  roleId               String? // New: Links to dynamic Role
  status               UserStatus @default(ACTIVE)
  lastLoginAt          DateTime?
  passwordResetToken   String?
  passwordResetExpires DateTime?
  createdAt            DateTime   @default(now())
  updatedAt            DateTime   @updatedAt

  // Relations
  employee        Employee?
  client          Client?
  admin           Admin?
  sessions        Session[]
  auditLogs       AuditLog[]
  adjustmentsMade TimeAdjustment[] @relation("AdjustmentsMade")
  dynamicRole     Role?            @relation(fields: [roleId], references: [id])
  createdTasks    Task[]

  @@map("users")
}

model Session {
  id        String   @id @default(uuid())
  userId    String
  token     String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())
  isActive  Boolean  @default(true)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

// ============================================
// EMPLOYEE
// ============================================

model Employee {
  id                       String           @id @default(uuid())
  userId                   String           @unique
  firstName                String
  lastName                 String
  profilePhoto             String?
  countryCode              String?          @default("+1")
  phone                    String?
  address                  String?
  emergencyContact         String?
  hireDate                 DateTime?
  terminationDate          DateTime?
  payableRate              Decimal?         @db.Decimal(10, 2)
  billingRate              Decimal?         @db.Decimal(10, 2)
  overtimeRate             Decimal?         @default(1) @db.Decimal(10, 2)
  deduction                Decimal?         @default(0) @db.Decimal(10, 2)
  onboardingStatus         OnboardingStatus @default(PENDING_AGREEMENT)
  personalEmail            String?
  kycStatus                KycStatus        @default(PENDING)
  kycReviewedAt            DateTime?
  kycReviewerId            String?
  kycRejectionNote         String?
  governmentIdType         String?
  governmentIdUrl          String?
  governmentIdStatus       KycStatus        @default(PENDING)
  governmentIdRejectNote   String?
  governmentId2Type        String?
  governmentId2Url         String?
  governmentId2Status      KycStatus        @default(PENDING)
  governmentId2RejectNote  String?
  proofOfAddressType       String?
  proofOfAddressUrl        String?
  proofOfAddressStatus     KycStatus        @default(PENDING)
  proofOfAddressRejectNote String?
  createdAt                DateTime         @default(now())
  updatedAt                DateTime         @updatedAt

  // Notification preferences
  notifyScheduleChanges Boolean @default(true)
  notifyShiftReminders  Boolean @default(true)
  notifyLeaveApprovals  Boolean @default(true)
  notifyPushMessages    Boolean @default(false)
  notifyWeeklySummary   Boolean @default(true)

  // Relations
  user               User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  clientAssignments  ClientEmployee[]
  groupAssignments   GroupEmployee[]
  workSessions       WorkSession[]
  schedules          Schedule[]
  timeRecords        TimeRecord[]
  leaveRequests      LeaveRequest[]
  supportTickets     SupportTicket[]
  wellbeingCheckins  WellbeingCheckin[]
  emergencyContacts  EmergencyContact[]
  tasks              Task[]
  conversations      Conversation[]
  autoApprovalLogs   AutoApprovalLog[]
  rateChanges        RateChangeHistory[]
  payrollAdjustments PayrollAdjustment[]
  payslips           Payslip[]
  clientRequests     ClientRequest[]

  @@map("employees")
}

// ============================================
// CLIENT
// ============================================

model Client {
  id               String           @id @default(uuid())
  userId           String           @unique
  companyName      String
  contactPerson    String
  countryCode      String?          @default("+1")
  phone            String?
  address          String?
  timezone         String           @default("UTC")
  logoUrl          String? // Company logo/profile photo
  onboardingStatus OnboardingStatus @default(PENDING_AGREEMENT)
  agreementType    AgreementType?
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt

  // Relations
  user             User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  contacts         ClientContact[]
  employees        ClientEmployee[]
  groups           ClientGroup[]
  clientPolicies   ClientPolicy?
  holidays         ClientHoliday[]
  timeRecords      TimeRecord[]
  leaveRequests    LeaveRequest[]
  agreement        ClientAgreement?
  tasks            Task[]
  conversations    Conversation[]
  invoices         Invoice[]
  autoApprovalLogs AutoApprovalLog[]
  payslips         Payslip[]
  clientRequests   ClientRequest[]
  payments         Payment[]

  @@map("clients")
}

model ClientContact {
  id        String  @id @default(uuid())
  clientId  String
  name      String
  position  String?
  phone     String?
  email     String?
  isPrimary Boolean @default(false)

  client Client @relation(fields: [clientId], references: [id], onDelete: Cascade)

  @@map("client_contacts")
}

model ClientAgreement {
  id             String        @id @default(uuid())
  clientId       String        @unique
  agreementType  AgreementType
  signedAt       DateTime?
  signedByName   String?
  signedByIP     String?
  signatureImage String?

  // Business Entity Info
  businessName    String?
  businessAddress String?
  businessCity    String?
  businessState   String?
  businessZip     String?
  businessEIN     String?

  // Signer Individual Info
  signerName    String?
  signerAddress String?
  signerCity    String?
  signerState   String?
  signerZip     String?

  // Payment method: 'credit_card', 'ach', 'both'
  paymentMethod String?

  // Credit Card (Exhibit B Section 1)
  ccCardholderName String?
  ccBillingAddress String?
  ccCityStateZip   String? // deprecated: kept for backward compat
  ccCity           String?
  ccState          String?
  ccZip            String?
  ccCardType       String?
  ccCardNumber     String?
  ccExpiration     String?
  ccCVV            String?

  // ACH (Exhibit B Section 2)
  achAccountHolder String?
  achBankName      String?
  achRoutingNumber String?
  achAccountNumber String?
  achAccountType   String?

  // Sola Payment Tokens (PCI-compliant tokenized storage)
  solaCardToken    String?   // xToken from Sola for credit card
  solaAchToken     String?   // xToken from Sola for ACH
  solaCardLastFour String?   // Last 4 digits of tokenized card
  solaCardType     String?   // Card brand from Sola (Visa, Mastercard, etc.)

  // Signed PDF data (base64)
  signedPdfData String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  client Client @relation(fields: [clientId], references: [id], onDelete: Cascade)

  @@map("client_agreements")
}

model ClientEmployee {
  id         String   @id @default(uuid())
  clientId   String
  employeeId String
  assignedAt DateTime @default(now())
  isActive   Boolean  @default(true)

  // Optional per-employee rate override (if null, uses client default)
  hourlyRate   Decimal? @db.Decimal(10, 2)
  overtimeRate Decimal? @db.Decimal(10, 2)

  // Optional per-employee PTO override (if null, uses client policy default)
  ptoAllowPaidLeave        Boolean?
  ptoEntitlementType       PaidLeaveEntitlementType?
  ptoAnnualDays            Int?
  ptoAccrualRatePerMonth   Decimal?                  @db.Decimal(5, 2)
  ptoMaxCarryoverDays      Int?
  ptoCarryoverExpiryMonths Int?
  ptoAllowUnpaidLeave      Boolean?
  ptoAllowPaidHolidays     Boolean?
  ptoAllowUnpaidHolidays   Boolean?

  client   Client   @relation(fields: [clientId], references: [id], onDelete: Cascade)
  employee Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  @@unique([clientId, employeeId])
  @@map("client_employees")
}

model ClientPolicy {
  id       String @id @default(uuid())
  clientId String @unique

  // Billing/Rate settings
  defaultHourlyRate   Decimal @default(0) @db.Decimal(10, 2)
  defaultOvertimeRate Decimal @default(1) @db.Decimal(10, 2) // If 0, uses 1 hourly rate
  currency            String  @default("USD")
  paymentTermsDays    Int     @default(15) // Days after period end for invoice due date

  // Leave policy settings
  allowPaidLeave           Boolean                  @default(false)
  paidLeaveEntitlementType PaidLeaveEntitlementType @default(NONE)
  annualPaidLeaveDays      Int                      @default(0)
  accrualRatePerMonth      Decimal?                 @db.Decimal(5, 2) // For ACCRUED type
  milestoneYearsRequired   Int? // For MILESTONE type
  milestoneBonusDays       Int? // Extra days after milestone
  maxCarryoverDays         Int                      @default(0) // Max days to carry to next year
  carryoverExpiryMonths    Int? // Months until carryover expires

  allowUnpaidLeave                 Boolean @default(true)
  requireTwoWeeksNotice            Boolean @default(true)
  requireTwoWeeksNoticePaidLeave   Boolean @default(true)
  requireTwoWeeksNoticeUnpaidLeave Boolean @default(true)

  // Holiday settings
  allowPaidHolidays       Boolean @default(false)
  paidHolidayType         String  @default("federal")
  numberOfPaidHolidays    Int     @default(0)
  selectedFederalHolidays String? // JSON array of selected holiday keys e.g. ["new_years","mlk","christmas"]
  allowUnpaidHolidays     Boolean @default(false)
  unpaidHolidayType       String  @default("federal")
  numberOfUnpaidHolidays  Int     @default(0)

  allowOvertime            Boolean @default(true)
  overtimeRequiresApproval Boolean @default(true)

  // Invoice configuration
  invoiceByGroup Boolean @default(false) // true = generate separate invoices per group

  // Auto-approve configuration
  autoApproveTimesheets Boolean @default(false)
  autoApproveMinutes    Int     @default(1440)

  // Notification preferences
  notifyTimeEntrySubmissions Boolean @default(true)
  notifyOvertimeAlerts       Boolean @default(true)
  notifyLeaveRequests        Boolean @default(true)
  notifyWeeklySummary        Boolean @default(false)
  notifyInvoice              Boolean @default(true)

  // System preferences
  dateFormat        String @default("MM/DD/YYYY")
  timeFormat        String @default("12-hour")
  workWeekStart     String @default("Sunday")
  overtimeThreshold Int    @default(40)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  client Client @relation(fields: [clientId], references: [id], onDelete: Cascade)

  @@map("client_policies")
}

model ClientHoliday {
  id              String   @id @default(uuid())
  clientId        String
  date            DateTime @db.Date
  name            String
  isAutoGenerated Boolean  @default(false)
  holidayKey      String? // Key from US_FEDERAL_HOLIDAYS e.g. "new_years", null for custom

  client Client @relation(fields: [clientId], references: [id], onDelete: Cascade)

  @@map("client_holidays")
}

// ============================================
// ADMIN
// ============================================

model Admin {
  id          String   @id @default(uuid())
  userId      String   @unique
  firstName   String
  lastName    String
  countryCode String?  @default("+1")
  phone       String?
  department  String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user              User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  ticketAssignments SupportTicket[] @relation("AssignedAdmin")

  @@map("admins")
}

// ============================================
// WORK SESSIONS & TIME TRACKING
// ============================================

model WorkSession {
  id                 String            @id @default(uuid())
  employeeId         String
  startTime          DateTime
  endTime            DateTime?
  status             WorkSessionStatus @default(ACTIVE)
  totalBreakMinutes  Int               @default(0)
  notes              String?
  ipAddress          String? // IP address at clock in
  arrivalStatus      String? // 'Early', 'On Time', 'Late', 'No Schedule'
  lateMinutes        Int? // Minutes late (null if not late)
  shiftEndNotifiedAt DateTime? // When the 5-min shift-ending warning was sent
  shiftEndPausedAt   DateTime? // When the controlled pause started at shift end
  shiftEndResumedAt  DateTime? // When employee chose to continue working
  shiftEndAction     String? // 'CONTINUE_WORKING' | 'STAY_CLOCKED_OUT' | 'AUTO_TIMEOUT'
  scheduledStartTime String? // HH:MM — shift start captured at clock-in
  scheduledEndTime   String? // HH:MM — shift end captured at clock-in
  isManual           Boolean           @default(false)
  createdAt          DateTime          @default(now())
  updatedAt          DateTime          @updatedAt

  employee Employee     @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  breaks   Break[]
  logs     SessionLog[]

  @@map("work_sessions")
}

model SessionLog {
  id            String   @id @default(uuid())
  workSessionId String
  userId        String? // Who performed the action
  userName      String? // Name of user for display
  action        String // CLOCK_IN, CLOCK_OUT, BREAK_START, BREAK_END, NOTES_UPDATED, IP_CHANGED, etc.
  message       String // Human-readable log message
  ipAddress     String?
  metadata      Json? // Additional data
  createdAt     DateTime @default(now())

  workSession WorkSession @relation(fields: [workSessionId], references: [id], onDelete: Cascade)

  @@index([workSessionId, createdAt])
  @@map("session_logs")
}

model Break {
  id              String    @id @default(uuid())
  workSessionId   String
  startTime       DateTime
  endTime         DateTime?
  durationMinutes Int?
  createdAt       DateTime  @default(now())

  workSession WorkSession @relation(fields: [workSessionId], references: [id], onDelete: Cascade)

  @@map("breaks")
}

model TimeRecord {
  id                    String               @id @default(uuid())
  employeeId            String
  clientId              String
  date                  DateTime             @db.Date
  scheduledStart        DateTime?
  scheduledEnd          DateTime?
  actualStart           DateTime?
  actualEnd             DateTime?
  billingStart          DateTime?
  billingEnd            DateTime?
  billingMinutes        Int                  @default(0)
  isLate                Boolean              @default(false)
  totalMinutes          Int                  @default(0)
  breakMinutes          Int                  @default(0)
  overtimeMinutes       Int                  @default(0)
  shiftExtensionStatus  ShiftExtensionStatus @default(NONE)
  shiftExtensionMinutes Int                  @default(0)
  shiftExtensionReason  String?
  extraTimeStatus       ShiftExtensionStatus @default(NONE)
  extraTimeMinutes      Int                  @default(0)
  status                ApprovalStatus       @default(PENDING)
  approvedBy            String?
  approvedAt            DateTime?
  adjustedBy            String?
  adjustedAt            DateTime?
  adjustmentNotes       String?
  originalMinutes       Int?
  revisionReason        String?
  revisionRequestedBy   String?
  revisionRequestedAt   DateTime?
  invoiceId             String? // Set when this record is included in an invoice; null = not yet invoiced
  createdAt             DateTime             @default(now())
  updatedAt             DateTime             @updatedAt

  employee    Employee         @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  client      Client           @relation(fields: [clientId], references: [id], onDelete: Cascade)
  adjustments TimeAdjustment[]

  @@unique([employeeId, clientId, date])
  @@index([invoiceId])
  @@map("time_records")
}

// Time Adjustment History (detailed tracking)
model TimeAdjustment {
  id           String   @id @default(uuid())
  timeRecordId String
  adjustedBy   String
  adjustedAt   DateTime @default(now())
  reason       String // Mandatory justification

  // What was changed
  fieldChanged String // e.g., "totalMinutes", "actualStart", "actualEnd"
  oldValue     String? // Original value (as string for flexibility)
  newValue     String // New value

  // For time changes specifically
  oldTotalMinutes   Int?
  newTotalMinutes   Int?
  minutesDifference Int? // Positive = added, Negative = removed

  // Re-approval tracking
  requiresReapproval Boolean   @default(true)
  clientReapprovedBy String?
  clientReapprovedAt DateTime?

  createdAt DateTime @default(now())

  timeRecord TimeRecord @relation(fields: [timeRecordId], references: [id], onDelete: Cascade)
  adjuster   User       @relation("AdjustmentsMade", fields: [adjustedBy], references: [id])

  @@index([timeRecordId])
  @@index([adjustedBy])
  @@index([adjustedAt])
  @@map("time_adjustments")
}

// ============================================
// AUTO-APPROVAL LOG
// ============================================

model AutoApprovalLog {
  id             String    @id @default(uuid())
  timeRecordId   String
  employeeId     String
  clientId       String
  recordDate     DateTime  @db.Date
  scheduledEnd   String // The schedule endTime that was used (HH:MM)
  approvalDelay  Int // autoApproveMinutes setting at time of approval
  approvedAt     DateTime  @default(now())
  actualStart    DateTime?
  actualEnd      DateTime?
  totalMinutes   Int       @default(0)
  clientTimezone String    @default("UTC")

  employee Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  client   Client   @relation(fields: [clientId], references: [id], onDelete: Cascade)

  @@index([clientId])
  @@index([employeeId])
  @@index([approvedAt])
  @@map("auto_approval_logs")
}

// ============================================
// AUDIT LOG (General System Audit Trail)
// ============================================

enum AuditAction {
  CREATE
  UPDATE
  DELETE
  APPROVE
  REJECT
  LOGIN
  LOGOUT
  EXPORT
  ADJUSTMENT
}

model AuditLog {
  id          String      @id @default(uuid())
  userId      String
  action      AuditAction
  entityType  String // e.g., "TimeRecord", "LeaveRequest", "Employee"
  entityId    String? // ID of the affected entity
  description String // Human-readable description

  // Change tracking
  oldValues Json? // Previous state (for updates)
  newValues Json? // New state (for creates/updates)

  // Context
  ipAddress String?
  userAgent String?
  metadata  Json? // Additional context-specific data

  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([entityType, entityId])
  @@index([action])
  @@index([createdAt])
  @@map("audit_logs")
}

// ============================================
// SCHEDULES
// ============================================

model Schedule {
  id            String    @id @default(uuid())
  employeeId    String
  dayOfWeek     Int // 0-6 (Sunday-Saturday)
  startTime     String // HH:MM format
  endTime       String // HH:MM format
  isActive      Boolean   @default(true)
  effectiveFrom DateTime
  effectiveTo   DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  employee Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  @@map("schedules")
}

// ============================================
// LEAVE BALANCES & REQUESTS
// ============================================

model LeaveBalance {
  id         String @id @default(uuid())
  employeeId String
  clientId   String
  year       Int // Year the balance applies to

  // Paid leave tracking
  paidLeaveEntitled  Decimal @default(0) @db.Decimal(5, 2) // Total entitled days
  paidLeaveUsed      Decimal @default(0) @db.Decimal(5, 2) // Days used
  paidLeaveCarryover Decimal @default(0) @db.Decimal(5, 2) // Carried from previous year
  paidLeavePending   Decimal @default(0) @db.Decimal(5, 2) // Pending approval

  // Unpaid leave tracking
  unpaidLeaveTaken   Decimal @default(0) @db.Decimal(5, 2) // Unpaid days taken
  unpaidLeavePending Decimal @default(0) @db.Decimal(5, 2) // Pending approval

  // Accrual tracking (for ACCRUED type)
  lastAccrualDate DateTime?
  accruedToDate   Decimal   @default(0) @db.Decimal(5, 2) // Total accrued so far

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([employeeId, clientId, year])
  @@index([employeeId, year])
  @@map("leave_balances")
}

model LeaveBalanceAdjustment {
  id             String   @id @default(uuid())
  employeeId     String
  clientId       String
  year           Int
  adjustmentType String // 'ADD', 'DEDUCT', 'CARRYOVER', 'ACCRUAL', 'RESET'
  days           Decimal  @db.Decimal(5, 2)
  reason         String
  adjustedBy     String // Admin who made the adjustment
  adjustedByName String?
  createdAt      DateTime @default(now())

  @@index([employeeId, year])
  @@map("leave_balance_adjustments")
}

model LeaveRequest {
  id               String      @id @default(uuid())
  employeeId       String
  clientId         String
  leaveType        LeaveType
  startDate        DateTime    @db.Date
  endDate          DateTime    @db.Date
  reason           String?
  status           LeaveStatus @default(PENDING)
  clientApprovedAt DateTime?
  clientApprovedBy String?
  adminApprovedAt  DateTime?
  adminApprovedBy  String?
  rejectedAt       DateTime?
  rejectedBy       String?
  rejectionReason  String?
  isShortNotice    Boolean     @default(false)
  createdAt        DateTime    @default(now())
  updatedAt        DateTime    @updatedAt

  employee Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  client   Client   @relation(fields: [clientId], references: [id], onDelete: Cascade)

  @@map("leave_requests")
}

// ============================================
// SUPPORT TICKETS
// ============================================

model SupportTicket {
  id              String         @id @default(uuid())
  employeeId      String
  assignedAdminId String?
  subject         String
  description     String
  status          TicketStatus   @default(OPEN)
  priority        TicketPriority @default(MEDIUM)
  resolvedAt      DateTime?
  closedAt        DateTime?
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt

  employee      Employee        @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  assignedAdmin Admin?          @relation("AssignedAdmin", fields: [assignedAdminId], references: [id])
  messages      TicketMessage[]

  @@map("support_tickets")
}

model TicketMessage {
  id         String   @id @default(uuid())
  ticketId   String
  senderId   String
  senderType String // 'employee' or 'admin'
  message    String
  isInternal Boolean  @default(false)
  createdAt  DateTime @default(now())

  ticket SupportTicket @relation(fields: [ticketId], references: [id], onDelete: Cascade)

  @@map("ticket_messages")
}

// ============================================
// WELLBEING & ENGAGEMENT
// ============================================

model WellbeingCheckin {
  id         String   @id @default(uuid())
  employeeId String
  date       DateTime @db.Date
  mood       Int // 1-5 scale
  comment    String?
  createdAt  DateTime @default(now())

  employee Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  @@unique([employeeId, date])
  @@map("wellbeing_checkins")
}

// ============================================
// NOTIFICATIONS
// ============================================

enum NotificationType {
  APPROVAL_REQUIRED
  APPROVAL_RECEIVED
  TIME_APPROVED
  TIME_REJECTED
  REVISION_REQUESTED
  LEAVE_REQUEST
  LEAVE_APPROVED
  LEAVE_REJECTED
  OVERTIME_REQUEST
  OVERTIME_APPROVED
  OVERTIME_REJECTED
  PAYROLL_REMINDER
  SCHEDULE_CHANGE
  SYSTEM_ALERT
  TASK_ASSIGNED
  TASK_STATUS_CHANGED
  TASK_COMMENTED
  TASK_UPDATED
  CHAT_MESSAGE
  TIMESHEET_AUTO_APPROVED
  INVOICE_GENERATED
  SHIFT_ENDING
  SHIFT_ENDING_OT_APPROVED
  AUTO_CLOCK_OUT
  SUPPORT_TICKET
}

enum MessageType {
  TEXT
  AUDIO
  FILE
  IMAGE
  VIDEO
}

model Notification {
  id        String           @id @default(uuid())
  userId    String
  title     String
  message   String
  type      NotificationType
  data      Json? // Additional data (e.g., recordId, employeeId)
  actionUrl String? // URL to navigate to when clicked
  isRead    Boolean          @default(false)
  readAt    DateTime?
  createdAt DateTime         @default(now())

  @@index([userId, isRead])
  @@index([userId, createdAt])
  @@map("notifications")
}

// ============================================
// OVERTIME REQUESTS
// ============================================

enum OvertimeStatus {
  PENDING
  APPROVED
  REJECTED
}

enum OvertimeType {
  SHIFT_EXTENSION
  OFF_SHIFT
}

enum ShiftExtensionStatus {
  NONE
  APPROVED
  PENDING
  UNAPPROVED
  DENIED
}

model OvertimeRequest {
  id                 String         @id @default(uuid())
  employeeId         String
  clientId           String
  date               DateTime       @db.Date
  type               OvertimeType   @default(SHIFT_EXTENSION)
  requestedMinutes   Int
  estimatedEndTime   String? // HH:MM format — shift extension end time
  requestedStartTime String? // HH:MM format — off-shift start time
  requestedEndTime   String? // HH:MM format — off-shift end time
  reason             String
  isAutoGenerated    Boolean        @default(false) // true = employee worked without prior approval, false = pre-requested
  status             OvertimeStatus @default(PENDING)
  approvedBy         String?
  approvedAt         DateTime?
  rejectedBy         String?
  rejectedAt         DateTime?
  rejectionReason    String?
  approvalNotes      String? // Admin/client notes on approval or rejection
  createdAt          DateTime       @default(now())
  updatedAt          DateTime       @updatedAt

  @@index([clientId, status])
  @@index([employeeId, date])
  @@map("overtime_requests")
}

// ============================================
// PAYROLL PERIODS
// ============================================

enum PayrollStatus {
  OPEN
  PENDING_APPROVAL
  LOCKED
  FINALIZED
}

model PayrollPeriod {
  id                 String        @id @default(uuid())
  clientId           String
  periodStart        DateTime      @db.Date
  periodEnd          DateTime      @db.Date
  cutoffDate         DateTime
  status             PayrollStatus @default(OPEN)
  totalHours         Decimal?      @db.Decimal(10, 2)
  totalOvertimeHours Decimal?      @db.Decimal(10, 2)
  approvedHours      Decimal?      @db.Decimal(10, 2)
  pendingHours       Decimal?      @db.Decimal(10, 2)
  finalizedAt        DateTime?
  finalizedBy        String?
  notes              String?
  createdAt          DateTime      @default(now())
  updatedAt          DateTime      @updatedAt

  @@unique([clientId, periodStart, periodEnd])
  @@index([clientId, status])
  @@map("payroll_periods")
}

model PayrollDateLog {
  id           String    @id @default(uuid())
  periodId     String
  previousDate DateTime?
  newDate      DateTime
  updatedBy    String
  notes        String?
  createdAt    DateTime  @default(now())

  @@index([periodId])
  @@map("payroll_date_logs")
}

enum AdjustmentType {
  BONUS
  DEDUCTION
}

model PayrollAdjustment {
  id          String         @id @default(uuid())
  employeeId  String
  type        AdjustmentType
  amount      Decimal        @db.Decimal(10, 2)
  reason      String
  periodStart DateTime       @db.Date
  periodEnd   DateTime       @db.Date
  createdBy   String
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt

  employee Employee @relation(fields: [employeeId], references: [id])

  @@index([employeeId, periodStart, periodEnd])
  @@map("payroll_adjustments")
}

enum ClientRequestStatus {
  PENDING
  APPROVED
  REJECTED
}

enum ClientRequestType {
  BONUS
  RAISE
}

model ClientRequest {
  id            String              @id @default(uuid())
  type          ClientRequestType
  employeeId    String
  clientId      String
  requestedBy   String
  // Bonus fields
  amount        Decimal?            @db.Decimal(10, 2)
  // Raise fields
  payRate       Decimal?            @db.Decimal(10, 2)
  billRate      Decimal?            @db.Decimal(10, 2)
  effectiveDate DateTime?           @db.Date
  // Common fields
  reason        String?
  status        ClientRequestStatus @default(PENDING)
  adminNotes    String?
  reviewedBy    String?
  reviewedAt    DateTime?
  createdAt     DateTime            @default(now())
  updatedAt     DateTime            @updatedAt

  employee Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  client   Client   @relation(fields: [clientId], references: [id], onDelete: Cascade)

  @@index([clientId])
  @@index([employeeId])
  @@index([status])
  @@index([type])
  @@map("client_requests")
}

// ============================================
// TASKS
// ============================================

enum TaskStatus {
  TODO
  IN_PROGRESS
  DONE
}

enum TaskPriority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

model Task {
  id          String       @id @default(uuid())
  clientId    String?
  employeeId  String?
  createdById String
  title       String
  description String?
  status      TaskStatus   @default(TODO)
  priority    TaskPriority @default(MEDIUM)
  isPersonal  Boolean      @default(false)
  dueDate     DateTime?    @db.Date
  completedAt DateTime?
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  client     Client?        @relation(fields: [clientId], references: [id], onDelete: Cascade)
  assignee   Employee?      @relation(fields: [employeeId], references: [id], onDelete: SetNull)
  createdBy  User           @relation(fields: [createdById], references: [id])
  comments   TaskComment[]
  activities TaskActivity[]

  @@index([clientId])
  @@index([employeeId])
  @@index([status])
  @@index([isPersonal, employeeId])
  @@map("tasks")
}

model TaskComment {
  id        String   @id @default(uuid())
  taskId    String
  userId    String
  message   String
  createdAt DateTime @default(now())

  task Task @relation(fields: [taskId], references: [id], onDelete: Cascade)

  @@index([taskId])
  @@map("task_comments")
}

enum TaskActivityAction {
  CREATED
  STATUS_CHANGED
  ASSIGNED
  UNASSIGNED
  PRIORITY_CHANGED
  DUE_DATE_CHANGED
  TITLE_UPDATED
  DESCRIPTION_UPDATED
  COMMENTED
}

model TaskActivity {
  id        String             @id @default(uuid())
  taskId    String
  userId    String
  action    TaskActivityAction
  oldValue  String?
  newValue  String?
  metadata  Json?
  createdAt DateTime           @default(now())

  task Task @relation(fields: [taskId], references: [id], onDelete: Cascade)

  @@index([taskId, createdAt])
  @@map("task_activities")
}

// ============================================
// CHAT / MESSAGING
// ============================================

model Conversation {
  id            String    @id @default(uuid())
  clientId      String
  employeeId    String
  lastMessageAt DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  client   Client    @relation(fields: [clientId], references: [id], onDelete: Cascade)
  employee Employee  @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  messages Message[]

  @@unique([clientId, employeeId])
  @@index([clientId])
  @@index([employeeId])
  @@map("conversations")
}

model Message {
  id             String      @id @default(uuid())
  conversationId String
  senderUserId   String
  content        String?
  messageType    MessageType @default(TEXT)
  fileUrl        String?
  fileKey        String?
  fileName       String?
  fileSize       Int?
  fileMimeType   String?
  audioDuration  Int?
  isRead         Boolean     @default(false)
  readAt         DateTime?
  createdAt      DateTime    @default(now())

  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  @@index([conversationId, createdAt])
  @@index([senderUserId])
  @@map("messages")
}

// ============================================
// SYSTEM SETTINGS
// ============================================

model SystemSettings {
  id        String   @id @default(uuid())
  category  String // 'general', 'notifications', 'security', 'billing'
  key       String
  value     String // JSON string for complex values
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([category, key])
  @@map("system_settings")
}

// ============================================
// GROUPS (Employee Grouping / Teams)
// ============================================

model Group {
  id          String   @id @default(uuid())
  name        String
  description String?
  billingRate Decimal? @db.Decimal(10, 2)
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  employees GroupEmployee[]
  clients   ClientGroup[]

  @@map("groups")
}

model ClientGroup {
  id          String   @id @default(uuid())
  clientId    String
  groupId     String
  billingRate Decimal? @db.Decimal(10, 2)
  assignedAt  DateTime @default(now())

  client Client @relation(fields: [clientId], references: [id], onDelete: Cascade)
  group  Group  @relation(fields: [groupId], references: [id], onDelete: Cascade)

  @@unique([clientId, groupId])
  @@map("client_groups")
}

model GroupEmployee {
  id         String   @id @default(uuid())
  groupId    String
  employeeId String
  assignedAt DateTime @default(now())

  group    Group    @relation(fields: [groupId], references: [id], onDelete: Cascade)
  employee Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  @@unique([groupId, employeeId])
  @@map("group_employees")
}

// ============================================
// EMERGENCY CONTACTS
// ============================================

model EmergencyContact {
  id           String   @id @default(uuid())
  employeeId   String
  name         String
  countryCode  String?  @default("+1")
  phone        String
  relationship String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  employee Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  @@map("emergency_contacts")
}

// ============================================
// INVOICES
// ============================================

enum InvoiceStatus {
  DRAFT
  SENT
  CLIENT_PAID
  PAID
  OVERDUE
  CANCELLED
}

model Invoice {
  id            String        @id @default(uuid())
  clientId      String
  invoiceNumber String        @unique
  periodStart   DateTime      @db.Date
  periodEnd     DateTime      @db.Date
  totalHours    Decimal       @default(0) @db.Decimal(10, 2)
  overtimeHours Decimal       @default(0) @db.Decimal(10, 2)
  subtotal      Decimal       @default(0) @db.Decimal(10, 2)
  total         Decimal       @default(0) @db.Decimal(10, 2)
  currency      String        @default("USD")
  status        InvoiceStatus @default(DRAFT)
  dueDate       DateTime      @db.Date
  notes         String?
  clientPaidAt  DateTime?
  clientPaidBy  String?
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  client    Client            @relation(fields: [clientId], references: [id], onDelete: Cascade)
  lineItems InvoiceLineItem[]
  payments  Payment[]

  @@index([clientId])
  @@index([status])
  @@index([createdAt])
  @@map("invoices")
}

// ============================================
// PAYMENTS (Sola Payment Gateway)
// ============================================

enum PaymentStatus {
  PENDING
  PROCESSING
  APPROVED
  DECLINED
  ERROR
  VOIDED
  REFUNDED
}

model Payment {
  id              String        @id @default(uuid())
  invoiceId       String
  clientId        String
  amount          Decimal       @db.Decimal(10, 2)
  currency        String        @default("USD")
  status          PaymentStatus @default(PENDING)
  paymentMethod   String        // 'credit_card' or 'ach'

  // Sola transaction details
  solaRefNum      String?       // xRefNum from Sola
  solaAuthCode    String?       // xAuthCode
  solaAuthAmount  Decimal?      @db.Decimal(10, 2) // xAuthAmount
  solaMaskedCard  String?       // xMaskedCardNumber
  solaCardType    String?       // xCardType
  solaToken       String?       // xToken returned
  solaBatch       String?       // xBatch
  solaError       String?       // xError if failed
  solaErrorCode   String?       // xErrorCode
  solaResult      String?       // xResult (A/D/E)
  solaDate        String?       // xDate from response

  processedAt     DateTime?
  processedBy     String?       // userId who initiated
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  invoice Invoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  client  Client  @relation(fields: [clientId], references: [id], onDelete: Cascade)

  @@index([invoiceId])
  @@index([clientId])
  @@index([status])
  @@index([solaRefNum])
  @@map("payments")
}

model InvoiceLineItem {
  id            String  @id @default(uuid())
  invoiceId     String
  employeeId    String
  employeeName  String
  groupName     String?
  hours         Decimal @default(0) @db.Decimal(10, 2)
  overtimeHours Decimal @default(0) @db.Decimal(10, 2)
  rate          Decimal @default(0) @db.Decimal(10, 2)
  overtimeRate  Decimal @default(0) @db.Decimal(10, 2)
  amount        Decimal @default(0) @db.Decimal(10, 2)
  notes         String?

  invoice Invoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)

  @@index([invoiceId])
  @@map("invoice_line_items")
}

// ============================================
// PAYSLIPS
// ============================================

model Payslip {
  id              String   @id @default(uuid())
  employeeId      String
  clientId        String
  periodStart     DateTime @db.Date
  periodEnd       DateTime @db.Date
  regularHours    Decimal  @default(0) @db.Decimal(10, 2)
  overtimeHours   Decimal  @default(0) @db.Decimal(10, 2)
  totalHours      Decimal  @default(0) @db.Decimal(10, 2)
  hourlyRate      Decimal  @default(0) @db.Decimal(10, 2)
  overtimeRate    Decimal  @default(0) @db.Decimal(10, 2)
  regularPay      Decimal  @default(0) @db.Decimal(10, 2)
  overtimePay     Decimal  @default(0) @db.Decimal(10, 2)
  ptoHours        Decimal  @default(0) @db.Decimal(10, 2)
  ptoPay          Decimal  @default(0) @db.Decimal(10, 2)
  totalBonuses    Decimal  @default(0) @db.Decimal(10, 2)
  totalDeductions Decimal  @default(0) @db.Decimal(10, 2)
  grossPay        Decimal  @default(0) @db.Decimal(10, 2)
  workDays        Int      @default(0)
  status          String   @default("GENERATED")
  createdAt       DateTime @default(now())

  employee Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  client   Client   @relation(fields: [clientId], references: [id], onDelete: Cascade)

  @@unique([employeeId, clientId, periodStart, periodEnd])
  @@index([employeeId])
  @@index([clientId])
  @@map("payslips")
}

// ============================================
// DOCUMENT TYPES (Master Data)
// ============================================

model DocumentType {
  id        String   @id @default(uuid())
  name      String
  category  String // "GOVERNMENT_ID" or "PROOF_OF_ADDRESS"
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([name, category])
  @@map("document_types")
}

// ============================================
// RATE CHANGE HISTORY
// ============================================

model RateChangeHistory {
  id            String   @id @default(uuid())
  employeeId    String
  clientId      String? // null if it's the employee's base rate change
  changedBy     String // userId of admin who made the change
  changedByName String?
  changeDate    DateTime @default(now())

  // What changed
  rateType String // 'BILLING_RATE' | 'PAYABLE_RATE' | 'HOURLY_RATE' | 'OVERTIME_RATE'
  oldValue Decimal? @db.Decimal(10, 2)
  newValue Decimal? @db.Decimal(10, 2)

  // Context
  source String // 'EMPLOYEE_PROFILE' | 'CLIENT_ASSIGNMENT'
  notes  String?

  employee Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  @@index([employeeId])
  @@index([clientId])
  @@index([changeDate])
  @@map("rate_change_history")
}
